{
    "new variable": {
        "prefix": "var",
        "body": [ "${1:newvar}=${2:\"val\"}" ]
    },

    "new function": {
        "prefix": "func",
        "body": [
            "${1:newfunc}() {",
                "\t${2:}",
                "}"
        ]
    },

    "new if": {
        "prefix": "if",
        "body": [
            "if [[ ${1:cond} ]]; then",
            "\t${2:}",
            "fi"
        ]
    },

    "new for each": {
      "prefix": "for each",
        "body": [
          "for item in list; do",
            "\t${1:}",
          "done"
        ]
    },

    "new for loop": {
        "prefix": "for loop",
        "body": [
          "for i in {1..10}; do",
            "\t${1:}",
          "done"
        ]
    },

    "echo": {
      "prefix": "echo",
        "body": [ "echo \"${1:Hello}\"" ]
    },

    "printf": {
        "prefix": "print",
        "body": [ "printf \"${1:Hello!}\"" ]
    },

    "shebang": {
        "prefix": "shebang",
        "body": [ "#!/usr/bin/env bash" ]
    }
}

